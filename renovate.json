{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
"packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "groupName": "all dependencies",
      "groupSlug": "all-deps",
      "rangeStrategy": "bump"
    }
  ],
  "prConcurrentLimit": 1,
  "labels": ["dependencies"]
}
