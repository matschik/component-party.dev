{
  "name": "component-party.dev",
  "version": "2.0.0",
  "private": true,
  "repository": "github:matschik/component-party.dev",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "format": "vp fmt",
    "lint": "vp lint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:ci": "vp fmt && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && vp lint",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "build:content": "vp node scripts/generateContent.ts --no-cache",
    "build:progress": "vp node scripts/generateReadMeProgress.ts",
    "prepare": "vp config --no-agent && svelte-kit sync || true",
    "test:unit": "vp test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test": "vp test --run && playwright test",
    "check:package-manager": "node scripts/check-package-manager.js"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "just-throttle": "^4.2.0",
    "lz-string": "^1.5.0",
    "runed": "^0.37.1",
    "sv-router": "^0.17.0"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.488",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.61.0",
    "@shikijs/markdown-it": "^4.2.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@sveltejs/vite-plugin-svelte-inspector": "5.0.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/folder-hash": "^4.0.4",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "autoprefixer": "^10.5.0",
    "chokidar": "^5.0.0",
    "eslint-plugin-svelte": "^3.19.0",
    "eta": "^4.6.0",
    "folder-hash": "^4.1.3",
    "html-minifier-terser": "^7.2.0",
    "just-kebab-case": "^4.2.0",
    "markdown-it": "^14.2.0",
    "micache": "^2.4.1",
    "package-directory": "^8.2.0",
    "prettier": "^3.8.4",
    "shiki": "^4.2.0",
    "svelte": "5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plus": "0.2.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
      "vitest": "4.1.9",
      "yaml": ">=2.8.3"
    }
  }
}
