import { bindValue } from "ripple";

const colors = [
  { id: 1, text: "red" },
  { id: 2, text: "blue" },
  { id: 3, text: "green" },
  { id: 4, text: "gray", isDisabled: true },
];

export component ColorSelect() {
  let selectedColorId = #ripple.track(2);

  <select {ref bindValue(selectedColorId)}>
    for (const color of colors) {
      <option value={color.id} disabled={color.isDisabled}>
        {color.text}
      </option>
    }
  </select>
}