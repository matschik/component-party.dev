import { bindGroup } from "ripple";

export component PickPill() {
  let picked = #ripple.track("red");

  <div>{`Picked: ${@picked}`}</div>

  <input
    id="blue-pill"
    type="radio"
    value="blue"
    {ref bindGroup(picked)}
  />
  <label for="blue-pill">{"Blue pill"}</label>

  <input
    id="red-pill"
    type="radio"
    value="red"
    {ref bindGroup(picked)}
  />
  <label for="red-pill">{"Red pill"}</label>
}