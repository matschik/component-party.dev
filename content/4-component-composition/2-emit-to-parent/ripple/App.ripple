import { AnswerButton } from "./AnswerButton.ripple";

export component App() {
  let isHappy = #ripple.track(true);

  function onAnswerNo() {
    @isHappy = false;
  }

  function onAnswerYes() {
    @isHappy = true;
  }

  <p>{`Are you happy?`}</p>
  <AnswerButton onYes={onAnswerYes} onNo={onAnswerNo} />
  <p style="font-size: 50px;">{@isHappy ? "😀" : "😥"}</p>
}